{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "pnpm": {
    "overrides": {
      "vite": "^8.0.0",
      "esbuild": "^0.27.0"
    }
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "worker:typecheck": "tsc -p worker/tsconfig.json",
    "cf:deploy": "pnpm generate && wrangler deploy",
    "cf:dev": "pnpm generate && wrangler dev",
    "db:migrate:local": "wrangler d1 migrations apply BS_SETTINGS --local",
    "db:migrate:remote": "wrangler d1 migrations apply BS_SETTINGS"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@nuxt/image": "^1.10.0",
    "@tanstack/vue-virtual": "^3.13.26",
    "@types/bcryptjs": "^3.0.0",
    "@types/formidable": "^3.4.5",
    "@types/uuid": "^10.0.0",
    "@vueuse/core": "^10.9.0",
    "@vueuse/motion": "^2.1.0",
    "aos": "^2.3.4",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.2",
    "formidable": "^3.5.4",
    "gsap": "^3.12.5",
    "idb-keyval": "^6.2.2",
    "jose": "^6.0.10",
    "jsonwebtoken": "^9.0.2",
    "markdown-it": "^14.1.0",
    "motion-v": "^1.3.0",
    "node-fetch": "^3.3.2",
    "nuxt": "3.15.4",
    "uuid": "^11.1.0",
    "vue": "latest",
    "vue-advanced-cropper": "^2.8.9",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.15.3",
    "@cloudflare/workers-types": "^4.20250424.0",
    "@nuxt/types": "^2.18.1",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@types/aos": "^3.0.7",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.14.0",
    "@types/node-fetch": "^2.6.12",
    "@vue/runtime-dom": "^3.5.13",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sass": "^1.71.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.8.2",
    "vite": "^8.0.0",
    "vue-tsc": "^2.2.8",
    "wrangler": "^4.51.0"
  }
}
