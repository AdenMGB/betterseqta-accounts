# Local dev only: proxy /api to this backend when running `pnpm dev` (default: production)
# NUXT_DEV_API_PROXY="https://accounts.betterseqta.org"

# MySQL Database connection
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"
 
# JWT secret for signing tokens
JWT_SECRET="your_jwt_secret_here"

# SMTP2GO configuration for password reset emails
SMTP2GO_API_KEY="your_smtp2go_api_key_here"
SMTP2GO_FROM_EMAIL="noreply@yourdomain.com"
APP_URL="https://accounts.betterseqta.org"

# Discord OAuth configuration
DISCORD_CLIENT_ID="130000"
DISCORD_CLIENT_SECRET="Sz....."
DISCORD_REDIRECT_URI="https://accounts.betterseqta.org/api/oauth/discord/callback"

# Google Calendar OAuth (BetterSEQTA+ extension — server-side token exchange)
GOOGLE_OAUTH_CLIENT_ID="your_client_id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="GOCSPX-your_client_secret"

# Microsoft / Outlook Calendar OAuth (BetterSEQTA+ extension — server-side token exchange)
MICROSOFT_CALENDAR_CLIENT_ID="your_azure_application_client_id"
MICROSOFT_CALENDAR_CLIENT_SECRET="your_azure_client_secret"
MICROSOFT_CALENDAR_REDIRECT_URI="https://accounts.betterseqta.org/auth/microsoft/calendar/callback"