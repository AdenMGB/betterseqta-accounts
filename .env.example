# MySQL Database connection
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"
 
# JWT secret for signing tokens
JWT_SECRET="your_jwt_secret_here"

# SMTP2GO configuration for password reset emails
